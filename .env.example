# 配置说明
# 复制此文件为 .env.local（本地开发）或在 Vercel 环境变量中设置

# 分享服务器地址（留空则使用默认公共服务器或长链接分享）
# For Create React App / standard Webpack
REACT_APP_SHARE_API_URL=

# For Vite
VITE_SHARE_API_URL=

# 智能拆分调试面板开关（仅本地开发使用，生产环境不要设置此项）
# 设为 true 时，工具栏会出现 🐛 调试按钮，可在前端直接编辑系统提示词并调用 GLM API
# 注意：API Key 仅存储在用户浏览器 localStorage 中，不会出现在代码或日志里
VITE_DEBUG_SPLIT=
